{
  "name": "norns-app",
  "version": "0.0.1",
  "description": "Starter template for Norns apps",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS='--preserve-symlinks' norns dev",
    "build": "NODE_OPTIONS='--preserve-symlinks' norns build",
    "preview": "norns preview",
    "check": "svelte-check --tsconfig ./jsconfig.json",
    "check:arch": "bun scripts/check-arch.js",
    "compare": "bun scripts/compare-examples.js",
    "migrate": "norns migrate"
  },
  "devDependencies": {
    "@human-synthesis/norns": "^0.0.7",
    "@human-synthesis/norns-core": "^0.0.7",
    "@human-synthesis/norns-ui": "^0.0.1",
    "@sveltejs/adapter-auto": "^3.3.1",
    "@sveltejs/kit": "^2.59.1",
    "@sveltejs/vite-plugin-svelte": "^4",
    "@tailwindcss/vite": "^4",
    "svelte": "^5.55.5",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4",
    "vite": "^5.4.0"
  },
  "packageManager": "bun@1.2.16",
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "lodash": "^4.18.1",
    "valibot": "^1.4.0"
  }
}
