form.flex.gap-2(onsubmit!="{handleSubmit}")
	input.todo-input(
		type="text"
		placeholder="What needs to be done?"
		bind:value!="{value}"
	)
	button.todo-add(type="submit" disabled!="{!value.trim()}") Add

<script>
	import { addTodo } from 'store'

	value = $state ''

	handleSubmit = (e) ->
		e.preventDefault()
		addTodo value
		value = ''
